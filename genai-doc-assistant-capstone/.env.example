# API keys (loaded into os.environ)
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here

# Optional external observability (Langfuse + LangSmith)
# Langfuse: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# LangSmith: https://smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=genai-doc-assistant

# Optional Redis cache (omit to use in-memory cache)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# QUERY_CACHE_TTL=3600

# CORS (comma-separated origins; optional if exposing API publicly)
# CORS_ALLOW_ORIGINS=http://your-ec2-ip:8501

# Streamlit → backend (set automatically in docker-compose.yml / docker-compose.ecr.yml)
# BACKEND_URL=http://backend:8000

# Dynamic config overrides (prefix APP_ + nested keys with __)
APP_ENV=dev
APP_RAG__CHUNK_SIZE=300
APP_RAG__CHUNK_OVERLAP=50
APP_MODELS__LLM_MODEL=groq/llama-3.3-70b-versatile
APP_MODELS__EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
APP_MODELS__EMBEDDING_DIM=768
APP_FILE_UPLOAD__MAX_FILE_SIZE_MB=10
APP_CACHE__ENABLED=true
APP_CACHE__TTL_SECONDS=3600
