# API keys (loaded into os.environ; not part of config.yaml)
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here

# Optional Langfuse / LangSmith
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true

# Dynamic config overrides (prefix APP_ + nested keys with __)
# These override values from config.yaml at runtime.
APP_ENV=dev
APP_RAG__CHUNK_SIZE=300
APP_RAG__CHUNK_OVERLAP=50
APP_MODELS__LLM_MODEL=groq/llama-3.3-70b-versatile
APP_MODELS__EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
APP_FILE_UPLOAD__MAX_FILE_SIZE_MB=10
