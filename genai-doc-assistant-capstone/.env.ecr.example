# ECR settings for docker-compose.ecr.yml (copy to .env.ecr on EC2)
#
# Single ECR repo with different tags per service (recommended):
#   digital-worker-studio:genai-backend-latest
#   digital-worker-studio:genai-streamlit-latest

ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY=digital-worker-studio
AWS_REGION=us-east-1
BACKEND_IMAGE_TAG=genai-backend-latest
STREAMLIT_IMAGE_TAG=genai-streamlit-latest
