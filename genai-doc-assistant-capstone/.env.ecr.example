# ECR settings for docker-compose.ecr.yml (copy to .env.ecr on EC2)
#
# One repo, two tags — must match what you pushed to ECR:
#   <ECR_REGISTRY>/digital-worker-studio:genai-backend-latest
#   <ECR_REGISTRY>/digital-worker-studio:genai-streamlit-latest
#
# Verify on EC2 before pull:
#   sudo docker compose -f docker-compose.ecr.yml --env-file .env --env-file .env.ecr config | grep image:

ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY=digital-worker-studio
AWS_REGION=us-east-1
BACKEND_IMAGE_TAG=genai-backend-latest
STREAMLIT_IMAGE_TAG=genai-streamlit-latest
