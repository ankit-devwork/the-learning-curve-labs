# ECR image coordinates (copy to .env.ecr on EC2 — not secret)
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY=insight-lab
API_IMAGE_TAG=api-latest
AWS_REGION=us-east-1

# Neo4j password for docker-compose.ecr.yml (must match backend/.env NEO4J_PASSWORD)
NEO4J_AUTH=neo4j/insightlab_dev_password
