# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Local dev (direct to FastAPI) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Vercel + EC2 HTTP proxy (recommended when API has no HTTPS) ---
# Client: same-origin path (browser → Vercel HTTPS → EC2 HTTP)
# NEXT_PUBLIC_API_URL=/api-backend
# Vercel project env (not NEXT_PUBLIC — set in Vercel dashboard):
# BACKEND_PROXY_URL=http://YOUR_EC2_PUBLIC_IP:8080

# Show backend JWT debug card on dashboard (dev only)
NEXT_PUBLIC_SHOW_DEV_PANEL=false
