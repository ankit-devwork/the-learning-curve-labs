# App
APP_ENV=development
APP_DEBUG=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=insightlab_dev_password

# Redis (local) — OR use Upstash vars below
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_DEFAULT_TTL=3600

# Upstash (production — leave empty for local Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# LLM (LiteLLM)
GROQ_API_KEY=your-groq-api-key
LITELLM_MODEL=groq/llama-3.3-70b-versatile

# Rate limits
RATE_LIMIT_CHAT_PER_MIN=20
RATE_LIMIT_QUIZ_PER_MIN=5
RATE_LIMIT_EXCEL_PER_MIN=10
RATE_LIMIT_UPLOAD_PER_HOUR=10

# Retry
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY_SEC=1.0
RETRY_MAX_DELAY_SEC=30.0

# Cache TTLs (seconds)
CACHE_CHAT_TTL=86400
CACHE_SUMMARY_TTL=604800
CACHE_QUIZ_TTL=604800
CACHE_EXCEL_TTL=86400

# Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# pycorekit logging
LOG_DIR=logs

# CORS (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Upload (Step 1.6)
UPLOAD_MAX_BYTES=20971520
