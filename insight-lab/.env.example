# InsightLab — root environment template
# Copy to .env for docker compose overrides (optional)

# Neo4j (local docker)
NEO4J_AUTH=neo4j/insightlab_dev_password

# Redis (local docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# Supabase (hosted project — https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend also needs these (see backend/.env.example)
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
# GROQ_API_KEY=

# Upstash (production cache — optional for local dev)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
